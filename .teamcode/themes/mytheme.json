{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#1a1a2e",
    "surface": "#16213e",
    "accent": "#0f3460",
    "text": "#e0e0e0",
    "muted": "#a0a0a0",
    "success": "#4caf50",
    "warning": "#ff9800",
    "error": "#f44336",
    "info": "#2196f3"
  },
  "theme": {
    "primary": {
      "dark": "accent",
      "light": "accent"
    },
    "background": {
      "dark": "bg",
      "light": "bg"
    },
    "backgroundPanel": {
      "dark": "surface",
      "light": "surface"
    },
    "text": {
      "dark": "text",
      "light": "text"
    },
    "textMuted": {
      "dark": "muted",
      "light": "muted"
    },
    "success": {
      "dark": "success",
      "light": "success"
    },
    "warning": {
      "dark": "warning",
      "light": "warning"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "info": {
      "dark": "info",
      "light": "info"
    }
  }
}
